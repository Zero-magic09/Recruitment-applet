/* 登录页面样式 */
.container {
  min-height: 100vh;
  background: #f0f7ff;
  padding: 40rpx 60rpx;
  position: relative;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  top: 60rpx;
  left: 40rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.back-icon {
  font-size: 40rpx;
  color: #64748b;
}

/* 头部 */
.header {
  margin-top: 40rpx;
  margin-bottom: 80rpx;
  text-align: center;
}

.role-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.15);
}

.role-icon.blue {
  background: linear-gradient(135deg, #3b82f6, #22d3ee);
}

.role-icon.purple {
  background: linear-gradient(135deg, #6366f1, #c084fc);
}

.icon-box {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* CSS 图标 - 公文包 */
.icon-briefcase {
  width: 56rpx;
  height: 42rpx;
  border: 5rpx solid white;
  border-radius: 10rpx;
  position: relative;
  box-sizing: border-box;
}
.icon-briefcase::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 6rpx;
  right: 6rpx;
  height: 5rpx;
  background: white;
  transform: translateY(-50%);
}
.icon-briefcase::after {
  content: '';
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 22rpx;
  height: 12rpx;
  border: 5rpx solid white;
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
  box-sizing: border-box;
  background: transparent;
}

/* CSS 图标 - 靶心 */
.icon-target {
  width: 52rpx;
  height: 52rpx;
  border: 5rpx solid white;
  border-radius: 50%;
  position: relative;
  box-sizing: border-box;
}
.icon-target::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 30rpx;
  height: 30rpx;
  border: 5rpx solid white;
  border-radius: 50%;
  box-sizing: border-box;
}
.icon-target::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  background: white;
  border-radius: 50%;
}

.title {
  font-size: 64rpx;
  font-weight: 800;
  color: #1e293b;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
  display: block;
}

/* 表单卡片 */
.card {
  background: #ffffff;
  border-radius: 50rpx;
  padding: 60rpx 50rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.03);
  border-top: 8rpx solid #2563eb;
}

.card.card-blue {
  border-top-color: #2563eb;
}

.card.card-purple {
  border-top-color: #6366f1;
}

.input-group {
  margin-bottom: 40rpx;
}

.label {
  font-size: 20rpx;
  font-weight: bold;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 20rpx;
}

.input-wrap {
  background: #f8fbff;
  border: 2rpx solid #e2e8f0;
  height: 100rpx;
  border-radius: 50rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.input-icon {
  font-size: 32rpx;
  color: #94a3b8;
  margin-right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 1;
}

/* CSS 图标 - 手机 */
.icon-phone {
  width: 22rpx;
  height: 36rpx;
  border: 3rpx solid #94a3b8;
  border-radius: 6rpx;
  position: relative;
  box-sizing: border-box;
}
.icon-phone::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #94a3b8;
}

/* CSS 图标 - 锁 */
.icon-lock {
  width: 26rpx;
  height: 22rpx;
  border: 3rpx solid #94a3b8;
  border-radius: 4rpx;
  position: relative;
  box-sizing: border-box;
  margin-top: 12rpx;
}
.icon-lock::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid #94a3b8;
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
  box-sizing: border-box;
}
.icon-lock::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #94a3b8;
}

.input-wrap input {
  font-size: 28rpx;
  flex: 1;
  color: #1e293b;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-weight: bold;
  font-size: 30rpx;
  color: #fff;
  margin-top: 40rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.1);
  border: none;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.btn-blue {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
  box-shadow: 0 20rpx 40rpx rgba(37, 99, 235, 0.3);
}

.submit-btn.btn-purple {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  box-shadow: 0 20rpx 40rpx rgba(99, 102, 241, 0.3);
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 忘记密码 */
.forget-pwd {
  text-align: center;
  font-size: 24rpx;
  font-weight: bold;
  margin: 40rpx 0;
}

.forget-pwd.blue {
  color: #2563eb;
}

.forget-pwd.purple {
  color: #6366f1;
}

/* 底部链接 */
.footer-link {
  text-align: center;
  margin-top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-text {
  font-size: 26rpx;
  color: #94a3b8;
}

.link-text {
  font-size: 26rpx;
  font-weight: normal;
  margin-left: 10rpx;
}

.link-text.blue {
  color: #2563eb;
}

.link-text.purple {
  color: #6366f1;
}
