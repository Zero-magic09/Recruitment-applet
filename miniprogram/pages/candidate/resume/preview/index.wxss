/* 简历预览页样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.content {
  padding: 30rpx;
}

.header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  gap: 30rpx;
  margin-bottom: 20rpx;
  width: 694rpx;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  object-fit: contain;
  display: block;
  background: rgba(255, 255, 255, 0.9);
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.detail {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.contact {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  width: 690rpx;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-action {
  font-size: 24rpx;
  color: #667eea;
  cursor: pointer;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
}

.intention {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item {
  font-size: 28rpx;
  color: #666;
}

.skills {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skill-tag {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  position: relative;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 30rpx;
  bottom: -30rpx;
  width: 2rpx;
  background: #eee;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  background: #667eea;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
  z-index: 1;
}

.timeline-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.timeline-time {
  font-size: 24rpx;
  color: #999;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.empty-tip {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  padding: 40rpx 0;
  display: block;
}

/* 技能证书样式 */
.certificates-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.certificate-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f6f8fb 0%, #ffffff 100%);
  border-radius: 12rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s;
}

.certificate-item:active {
  transform: scale(0.98);
  background: #f6f8fb;
}

.cert-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.cert-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cert-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.cert-meta {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #999;
}

.cert-score {
  color: #667eea;
  font-weight: 500;
}

.cert-skills {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}

.mini-tag {
  padding: 2rpx 12rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.cert-arrow {
  color: #ccc;
  font-size: 28rpx;
}

.empty-cert-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  text-align: center;
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.get-cert-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  margin-top: 10rpx;
}
