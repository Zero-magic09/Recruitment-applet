/* 面试列表页 - 全新优化样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fe 0%, #e8ebf5 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

.list {
  width: 100%;
}

/* 面试卡片 */
.interview-item {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: visible;
}

.interview-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  z-index: 1;
  border-radius: 24rpx 0 0 24rpx;
}

.item-content {
  padding: 32rpx;
}

/* 头部信息 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.job-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 状态标签 */
.status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
  flex-shrink: 0;
  white-space: nowrap;
  line-height: 1;
}

.status-pending {
  background: linear-gradient(135deg, #ffd700 0%, #ffa500 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 165, 0, 0.3);
}

.status-confirmed {
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(81, 207, 102, 0.3);
}

.status-completed {
  background: linear-gradient(135deg, #64b5f6 0%, #42a5f5 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(66, 165, 245, 0.3);
}

.status-cancelled {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff5252 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

/* 信息行 */
.info-row {
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f2ff 100%);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  flex-shrink: 0;
  line-height: 1.6;
}

.company-info .icon {
  display: inline-block;
  transform: translateY(-4rpx);
}

.value {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  filter: grayscale(0.5) opacity(0.4);
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
  max-width: 500rpx;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 20rpx;
}

.loading::before {
  content: '⏳';
  font-size: 60rpx;
  animation: rotate 1.5s linear infinite;
}

.loading text {
  color: #999;
  font-size: 28rpx;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
