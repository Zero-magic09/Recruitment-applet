/* 投递记录页 - 优化样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ebf5 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

.list {
  width: 100%;
}

.application-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: visible;
  backdrop-filter: blur(20rpx);
}

.item-content {
  padding: 32rpx;
}

.item-content:active {
  background: rgba(102, 126, 234, 0.03);
}

.application-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);  
  z-index: 1;
  border-radius: 24rpx 0 0 24rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.job-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
  line-height: 1;
}

.status-submitted {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(102, 126, 234, 0.25) 100%);
  color: #667eea;
  border: 1rpx solid rgba(102, 126, 234, 0.3);
}

.status-viewed {
  background: linear-gradient(135deg, rgba(33, 150, 243, 0.15) 0%, rgba(33, 150, 243, 0.25) 100%);
  color: #2196f3;
  border: 1rpx solid rgba(33, 150, 243, 0.3);
}

.status-interviewed {
  background: linear-gradient(135deg, #ffd700 0%, #ffa500 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 165, 0, 0.3);
}

.status-rejected {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff5252 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.status-accepted {
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(81, 207, 102, 0.3);
}

.status-hired {
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(81, 207, 102, 0.3);
}

.company-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-weight: 500;
}

.company-name::before {
  content: '🏢';
  font-size: 24rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time::before {
  content: '📅';
  font-size: 20rpx;
}

/* 面试按钮区域 */
.action-bar {
  display: flex;
  justify-content: flex-end;
  padding: 0 32rpx 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  margin-top: 16rpx;
  padding-top: 20rpx;
}

.interview-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  line-height: 1;
}

.interview-btn::after {
  border: none;
}

.interview-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.interview-btn .btn-icon {
  font-size: 28rpx;
  line-height: 1;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty::before {
  content: '📋';
  font-size: 120rpx;
  margin-bottom: 32rpx;
  filter: grayscale(0.3) opacity(0.6);
}

.empty {
  font-size: 32rpx;
  font-weight: bold;
  color: #666;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.loading {
  font-size: 28rpx;
  color: #999;
}
