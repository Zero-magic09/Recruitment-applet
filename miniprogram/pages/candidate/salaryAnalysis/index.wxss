/* 薪资分析页面 - 对齐求职者首页样式 */

/* ==================== 全局容器 ==================== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #e8ebf5 100%);
  padding-bottom: 40rpx;
}

/* ==================== 顶部筛选区域 ==================== */
.filter-section {
  background: transparent;
  padding: 0;
  margin: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 标签切换 */
.tabs {
  display: flex;
  justify-content: space-between;
  width: 675rpx;
  margin: 30rpx auto 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  gap: 0;
}

.tab {
  width: 110rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 选择器独立容器 */
.selector-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

/* 选择器 */
.selector-box {
  width: 675rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: center;
}

.selector {
  width: 100%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0rpx 0rpx 35rpx;
  border-radius: 12rpx;
  background: transparent;
  transition: all 0.3s;
}

.selector-value {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  text-align: center;
}

.selector-arrow {
  display: none;
}

/* ==================== 薪资分布卡片 ==================== */
.salary-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  width: 640rpx;
  margin: 0 auto 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.salary-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.card-title {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.title-subtitle {
  font-size: 26rpx;
  color: #666;
}

.live-tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 12rpx;
  font-weight: bold;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.live-dot {
  width: 8rpx;
  height: 8rpx;
  background: #ffffff;
  border-radius: 50%;
  animation: pulse-dot 1.5s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { 
    opacity: 1;
  }
  50% { 
    opacity: 0.4;
  }
}

.live-text {
  line-height: 1;
}

/* 分位数卡片 */
.percentile-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.percentile-box {
  flex: 1;
  padding: 20rpx;
  background: #f0f2ff;
  border-radius: 16rpx;
  text-align: center;
  border: 1rpx solid #e0e4ff;
  transition: all 0.3s;
}

.percentile-box:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
}

.percentile-highlight {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.percentile-label {
  display: block;
  font-size: 24rpx;
  color: #667eea;
  margin-bottom: 8rpx;
  line-height: 1;
  font-weight: 500;
}

.percentile-highlight .percentile-label {
  color: rgba(255, 255, 255, 0.9);
}

.percentile-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.percentile-highlight .percentile-value {
  color: #ffffff;
}

.unit-small {
  font-size: 24rpx;
  font-weight: 500;
  margin-left: 4rpx;
}

.percentile-desc {
  display: block;
  font-size: 20rpx;
  color: #999;
  line-height: 1;
}

.percentile-highlight .percentile-desc {
  color: rgba(255, 255, 255, 0.8);
}

/* 统计数据行 */
.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #f0f2ff;
  border-radius: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-item.stat-primary {
  flex: 1;
  display: flex;
  justify-content: center;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.stat-pill {
  display: inline-flex;
  align-items: center;
  padding: 0rpx 32rpx 35rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* ==================== 市场对比 ==================== */
.market-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  width: 640rpx;
  margin: 0 auto 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.market-section::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.market-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.market-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.market-subtitle {
  font-size: 22rpx;
  color: #999;
}

.market-card-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.market-card {
  padding: 20rpx;
  background: #f0f2ff;
  border-radius: 16rpx;
  border: 1rpx solid #e0e4ff;
  transition: all 0.3s;
}

.market-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
}

.market-card-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.market-icon-box {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.icon-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.icon-purple {
  background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
}

.market-text-group {
  flex: 1;
}

.market-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.market-value-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.market-value {
  font-size: 36rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.market-unit {
  font-size: 24rpx;
  color: #999;
}

.market-card-bottom {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.trend-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: bold;
}

.trend-icon {
  line-height: 1;
}

.trend-text {
  line-height: 1;
}

.trend-desc {
  font-size: 24rpx;
  color: #999;
}

/* ==================== 详细数据分布 ==================== */
.detail-distribution {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  width: 640rpx;
  margin: 0 auto 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.detail-distribution::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-line {
  width: 0;
  height: 0;
  margin-right: 0;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f0f2ff;
  border-radius: 16rpx;
  border: 1rpx solid #e0e4ff;
  transition: all 0.3s;
}

.detail-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
}

.detail-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-number {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
}

.detail-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.detail-value {
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.detail-count {
  font-size: 24rpx;
  color: #999;
}

/* ==================== 数据说明 ==================== */
.data-info {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  width: 640rpx;
  margin: 0 auto;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  position: relative;
  overflow: hidden;
}

.data-info::before {
  content: '';
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  top: -200rpx;
  right: -100rpx;
}

.data-info::after {
  content: '';
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  bottom: -150rpx;
  left: -80rpx;
}

.info-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.info-icon {
  font-size: 32rpx;
  color: #ffffff;
  line-height: 1;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.info-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  padding-left: 24rpx;
  position: relative;
}

.info-item::before {
  content: '•';
  position: absolute;
  left: 8rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: bold;
}

/* ==================== 加载中 ==================== */
.loading {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
