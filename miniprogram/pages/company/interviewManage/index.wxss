/* 企业面试管理页 - 优化样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ebf5 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

.list {
  width: 100%;
}

.interview-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
}

.interview-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.candidate-name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.status-text {
  transform: translateY(-13rpx);
}

.status-pending {
  background: linear-gradient(135deg, #ffd700 0%, #ffa500 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 165, 0, 0.3);
}

.status-confirmed {
  background: linear-gradient(135deg, #4caf50 0%, #45a049 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.3);
}

.status-completed {
  background: linear-gradient(135deg, #64b5f6 0%, #42a5f5 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(66, 165, 245, 0.3);
}

.status-cancelled {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.15) 0%, rgba(255, 107, 107, 0.25) 100%);
  border: 1rpx solid rgba(255, 107, 107, 0.3);
  color: #ff6b6b;
}

.job-title {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-weight: 500;
}

.job-title::before {
  content: '💼';
  font-size: 24rpx;
}

.job-title-text {
  transform: translateY(3rpx);
}

.info-row {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.6;
  display: flex;
  align-items: center;
}

.info-row:last-of-type {
  margin-bottom: 0;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  border-radius: 40rpx;
  padding: 16rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
}

.action-btn.confirm:active {
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.action-btn.reject-interview {
  background: #ffffff;
  color: #ff6b6b;
  border: 2rpx solid #ff6b6b;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.15);
}

.action-btn.reject-interview:active {
  background: rgba(255, 107, 107, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.2);
}

.action-btn.pass {
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(81, 207, 102, 0.3);
}

.action-btn.pass:active {
  box-shadow: 0 4rpx 12rpx rgba(81, 207, 102, 0.4);
}

.action-btn.reject {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff5252 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.3);
}

.action-btn.reject:active {
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.4);
}

.result {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  padding-top: 24rpx;
}

/* 结果徽章 - 背景容器 */
.result-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 48rpx;
  border-radius: 40rpx;
}

.passed-badge {
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  box-shadow: 0 6rpx 16rpx rgba(81, 207, 102, 0.3);
}

.failed-badge {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff5252 100%);
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.3);
}

/* 结果文字 */
.result-text {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.passed-text {
  color: #ffffff;
  transform: translateY(-15rpx);
}

.failed-text {
  color: #ffffff;
  transform: translateY(-15rpx);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty::before {
  content: '📋';
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty text {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 确认面试弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 580rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 44rpx;
  color: #999;
  line-height: 1;
  padding: 0 8rpx;
}

.modal-body {
  padding: 24rpx 28rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item .label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-item .input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.picker-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.form-item .textarea {
  width: 100%;
  min-height: 216rpx;
  padding: 12rpx 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 28rpx 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.modal-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: #f5f7fa;
  color: #666;
}

.modal-btn.cancel:active {
  background: #e8ebf0;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
}

.modal-btn.confirm:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}
