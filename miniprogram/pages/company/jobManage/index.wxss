/* 岗位管理页样式 - 优化版 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ebf5 100%);
  padding: 30rpx;
  box-sizing: border-box;
}

.list {
  width: 100%;
}

/* ========== 岗位卡片 ========== */
.job-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  backdrop-filter: blur(20rpx);
}

.job-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transform: scaleY(0);
  transition: transform 0.3s;
}

.job-item:active::before {
  transform: scaleY(1);
}

.job-item:active {
  transform: translateY(-6rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.2);
}

/* ========== 头部 ========== */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.job-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  word-break: break-all;
  margin-right: 16rpx;
}

.status-tag {
  display: inline-block;
  min-width: 120rpx;
  height: 48rpx;
  line-height: 16rpx;
  padding: 0 15rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
  text-align: center;
  box-sizing: border-box;
}

.status-tag text {
  transform: translateY(-5rpx);
}

.status-tag.active {
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(81, 207, 102, 0.3);
}

.status-tag.inactive {
  background: rgba(158, 158, 158, 0.15);
  color: #9e9e9e;
  border: 1rpx solid rgba(158, 158, 158, 0.3);
}

/* ========== 详细信息 ========== */
.job-detail {
  background: linear-gradient(135deg, #f8f9ff 0%, #f0f2ff 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.salary {
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.divider {
  color: #ddd;
  font-size: 24rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
}

/* ========== 技能标签 ========== */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.skill-tag {
  padding: 8rpx 20rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  font-size: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
  font-weight: 500;
}

/* ========== 操作按钮 ========== */
.actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 40rpx;
  padding: 18rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: none;
  line-height: 1;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
}

.action-btn.primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.action-btn.secondary {
  background: #ffffff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.action-btn.secondary:active {
  background: rgba(102, 126, 234, 0.1);
  transform: scale(0.96);
}

.action-btn.warning {
  background: #ffffff;
  color: #1976d2;
  border: 2rpx solid #1976d2;
}

.action-btn.warning:active {
  background: rgba(25, 118, 210, 0.1);
  transform: scale(0.96);
}

.action-btn.success {
  background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(81, 207, 102, 0.3);
}

.action-btn.success:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(81, 207, 102, 0.4);
}

.action-btn.danger {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.3);
}

.action-btn.danger:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.4);
}

.btn-icon {
  font-size: 26rpx;
  line-height: 1;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  filter: grayscale(0.3) opacity(0.6);
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

/* ========== 加载状态 ========== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.loading-icon {
  font-size: 60rpx;
  animation: rotate 2s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
