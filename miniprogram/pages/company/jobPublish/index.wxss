.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f5f5;
}

.content {
  flex: 1;
  width: 690rpx;
  padding-top: 30rpx;
  padding-bottom: 120rpx;
}

.section {
  background: #ffffff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

.form-item {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-item:focus-within {
  background: #ffffff;
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.label {
  width: 200rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.required {
  color: #ff4444;
  font-weight: bold;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.picker {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.salary-range {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.input-small {
  flex: 1;
  font-size: 28rpx;
  text-align: center;
}

.separator {
  font-size: 28rpx;
  color: #999;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.8;
  transition: all 0.3s;
  box-sizing: border-box;
}

.textarea:focus {
  background: #ffffff;
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.tag-input {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.tag-input .input {
  flex: 1;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  transition: all 0.3s;
}

.tag-input .input:focus {
  background: #ffffff;
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.add-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.add-btn::after {
  border: none;
}

.add-btn:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  transition: all 0.3s;
}

.tag:active {
  background: rgba(102, 126, 234, 0.2);
}

.benefit-tag {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.benefit-tag:active {
  background: rgba(102, 126, 234, 0.2);
}

.tag .remove-btn {
  font-size: 32rpx;
  font-weight: bold;
  color: #999;
  transition: all 0.3s;
}

.tag .remove-btn:active {
  color: #ff6b6b;
}

.upload-btn {
  background: #ffffff;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 40rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.upload-btn::after {
  border: none;
}

.upload-btn:active {
  background: rgba(102, 126, 234, 0.1);
  transform: scale(0.98);
}

.tip {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #4caf50;
  padding: 12rpx 20rpx;
  background: rgba(76, 175, 80, 0.1);
  border-radius: 8rpx;
  text-align: center;
}

.bottom-placeholder {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 690rpx;
  background: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
  border-radius: 16rpx 16rpx 0 0;
  z-index: 100;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}
