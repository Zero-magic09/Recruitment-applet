<!-- 投递列表页 -->
<view class="container">
  <!-- 岗位信息 -->
  <view class="job-header" wx:if="{{jobTitle}}">
    <text class="total-count">共收到 {{applications.length}} 份简历</text>
  </view>

  <!-- 投递列表 -->
  <view class="list">
    <view class="application-item" wx:for="{{applications}}" wx:key="_id">
      <!-- 头像和基本信息 -->
      <view class="item-header">
        <view class="avatar-section">
          <image class="avatar" src="{{item.resume.avatar || '/images/用户.png'}}" mode="aspectFill" />
          <view class="name-status-row">
            <text class="candidate-name">{{item.candidateName}}</text>
            <view class="status-badge status-badge-{{item.status}}">
              <text class="status-text">
                {{item.status === 'submitted' ? '📫 已投递' : 
                  item.status === 'viewed' ? '👀 已查看' : 
                  item.status === 'interviewed' ? '💼 面试中' : 
                  item.status === 'rejected' ? '❌ 已拒绝' : 
                  item.status === 'hired' ? '✅ 已录用' : 
                  item.status === 'accepted' ? '✅ 已录用' : '未知'}}
              </text>
            </view>
          </view>
        </view>
        <text class="apply-time">🕒 {{item.createTime}}</text>
      </view>
      
      <!-- 求职者详细信息 -->
      <view class="candidate-detail">
        <view class="detail-row" wx:if="{{item.resume.expectedPosition}}">
          <text class="detail-label">🎯 期望职位</text>
          <text class="detail-value">{{item.resume.expectedPosition}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">📞 联系电话</text>
          <text class="detail-value">{{item.candidatePhone}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.candidateEmail}}">
          <text class="detail-label">📧 邮箱地址</text>
          <text class="detail-value">{{item.candidateEmail}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.resume.workExperience}}">
          <text class="detail-label">💼 工作经验</text>
          <text class="detail-value">{{item.resume.workExperience}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.resume.education}}">
          <text class="detail-label">🎓 学历背景</text>
          <text class="detail-value">{{item.resume.education}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="actions">
        <button class="action-btn primary" bindtap="viewResume" data-application="{{item}}">
          <text class="btn-icon">📄</text>
          <text>查看简历</text>
        </button>
        <button class="action-btn secondary" bindtap="updateStatus" data-id="{{item._id}}" data-status="{{item.status}}">
          <text class="btn-icon">⚙️</text>
          <text>更新状态</text>
        </button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{!loading && applications.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无投递记录</text>
      <text class="empty-desc">该岗位还没有收到简历投递</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-icon">⏳</text>
    <text class="loading-text">加载中...</text>
  </view>
</view>
